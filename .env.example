# Smart Study Calendar — backend environment variables (all optional)
#
# Set these before running the backend to enable LLM-written explanations.
# Without them, the app runs in rule-based mode and still works fully.

# Your Anthropic API key (enables the AI assistant explanations)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: which model to use for explanations (default below).
# Use any chat model you have access to.
SSC_LLM_MODEL=claude-haiku-4-5-20251001
